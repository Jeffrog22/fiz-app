{
  "name": "fiz-app",
  "version": "1.0.0",
  "private": true,
  "description": "Aplicativo de lista de chamada para aulas de natação. Sistema de gestão de chamadas para piscinas de natação, unificando 4 unidades (Bela Vista, São Matheus, Vila e Parque) em uma única arquitetura multi-tenant.",
  "workspaces": ["frontend"],
  "scripts": {
    "prepare": "git config core.hooksPath .githooks",
    "install:backend": "cd backend && npm install",
    "install:frontend": "cd frontend && npm install",
    "install:all": "npm run install:backend && npm run install:frontend",
    "build:backend": "cd backend && npm run build",
    "build:frontend": "cd frontend && npm run build",
    "build": "npm run build:backend",
    "start": "cd backend && npm start",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "test": "cd backend && npm test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jeffrog22/fiz-app.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Jeffrog22/fiz-app/issues"
  },
  "homepage": "https://github.com/Jeffrog22/fiz-app#readme"
}
