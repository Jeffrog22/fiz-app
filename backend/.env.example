# Supabase
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_ANON_KEY=sua-chave-anon

# JWT (IMPORTANTE: Use uma chave complexa e única em produção!)
JWT_SECRET=seu-segredo-jwt-aqui
JWT_EXPIRES_IN=24h

# Server
PORT=3001
NODE_ENV=development

# CORS (IMPORTANTE: Defina a URL específica do seu frontend em produção, ex: https://meuapp.pages.dev)
# Múltiplas URLs separadas por vírgula: CORS_ORIGINS=https://app.meusite.com,https://admin.meusite.com
CORS_ORIGINS=*
FRONTEND_URL=*