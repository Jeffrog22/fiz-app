# Supabase
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_ANON_KEY=sua-chave-anon

# JWT (IMPORTANTE: Use uma chave complexa e única em produção!)
JWT_SECRET=seu-segredo-jwt-aqui
JWT_EXPIRES_IN=24h

# Server
PORT=3001
NODE_ENV=development

# CORS (IMPORTANTE: Defina a URL específica do seu frontend em produção, ex: https://meuapp.pages.dev)
FRONTEND_URL=*

# Rate Limit
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=5
ADMIN_KEY=3250