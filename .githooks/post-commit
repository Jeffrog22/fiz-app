#!/bin/sh
# Auto-creates git tag on every commit by bumping the latest tag
# Uses: v<major>.<minor>.<patch> scheme

LAST_TAG=$(git describe --tags --abbrev=0 2>/dev/null || echo "v0.0.0")
VERSION=${LAST_TAG#v}

MAJOR=$(echo "$VERSION" | cut -d. -f1)
MINOR=$(echo "$VERSION" | cut -d. -f2)
PATCH=$(echo "$VERSION" | cut -d. -f3)

# Strip any suffix like -rc1, -beta etc
PATCH=$(echo "$PATCH" | sed 's/[^0-9].*//')

# Default to 0 if empty
MAJOR=${MAJOR:-0}
MINOR=${MINOR:-0}
PATCH=${PATCH:-0}

PATCH=$((PATCH + 1))
NEW_TAG="v$MAJOR.$MINOR.$PATCH"

git tag "$NEW_TAG"
echo "post-commit: created tag $NEW_TAG (previous: $LAST_TAG)"
